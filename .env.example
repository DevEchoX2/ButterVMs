# Core
BUTTERVMS_SECRET_KEY=replace-with-long-random-string
BUTTERVMS_DB_PATH=/data/buttervms.db
BUTTERVMS_DEBUG=0
BUTTERVMS_SWEEPER_SECONDS=30

# VM runtime
BUTTERVMS_VNC_IMAGE=jlesage/firefox:latest
BUTTERVMS_CONTAINER_PREFIX=buttervms-session
BUTTERVMS_PUBLIC_VM_HOST=
BUTTERVMS_PUBLIC_VM_SCHEME=http
BUTTERVMS_PUBLIC_VM_HOST_TEMPLATE=

# Session limits
BUTTERVMS_STANDARD_MINUTES=45
BUTTERVMS_PREMIUM_MINUTES=480

# Admin API
BUTTERVMS_ADMIN_API_TOKEN=replace-with-private-admin-token
